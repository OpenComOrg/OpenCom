PORT=3003
MEDIA_HOST=0.0.0.0
MEDIA_SERVER_URL=https://media.example.com
MEDIA_WS_URL=wss://media.example.com/gateway
MEDIA_ALLOWED_ORIGINS=https://opencom.online,http://localhost:5173
MEDIA_TOKEN_SECRET=replace_me_with_a_long_random_secret
MEDIA_TOKEN_ISSUER=opencom-media
MEDIA_TOKEN_AUDIENCE=
MEDIA_SYNC_SECRET=replace_me_shared_node_sync_secret

# GCP deployment profile:
# - cloud-run: signaling/control-plane only, no public UDP expectations
# - gce: VM-hosted media plane
# - gke: k8s-hosted media plane
# - hybrid: Cloud Run signaling + separate UDP media plane
GCP_DEPLOYMENT_MODE=hybrid

# Current engine is a Go-native compatibility scaffold.
# It already supports token validation, room/session state, speaking, internal sync,
# and the existing gateway contract. Transport/media operations are intentionally
# stubbed behind this seam so we can swap in a real Pion/SFU engine incrementally.
WEBRTC_ENGINE=noop
WEBRTC_PUBLIC_HOST=
WEBRTC_UDP_MIN_PORT=40000
WEBRTC_UDP_MAX_PORT=40100
